{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "sync content",
      "type": "npm",
      "script": "sync",
      "options": {
        "cwd": "${workspaceFolder}/web"
      },
      "problemMatcher": []
    },
    {
      "label": "dev",
      "type": "npm",
      "script": "dev",
      "options": {
        "cwd": "${workspaceFolder}/web"
      },
      "dependsOn": ["sync content"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "build",
      "type": "npm",
      "script": "build",
      "options": {
        "cwd": "${workspaceFolder}/web"
      },
      "dependsOn": ["sync content"],
      "group": "build",
      "problemMatcher": []
    }
  ]
}

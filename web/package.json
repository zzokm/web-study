{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "sync": "node scripts/sync-content.mjs",
    "predev": "npm run copy-pdf-worker && npm run sync && npm run write-build-id",
    "prebuild": "npm run copy-pdf-worker && npm run sync && npm run write-build-id",
    "dev": "next dev --webpack",
    "build": "npm run audit:ci && next build --webpack",
    "start": "next start",
    "lint": "eslint src --max-warnings 0",
    "audit:ci": "node scripts/audit-ci.mjs",
    "validate:segments": "node scripts/validate-question-segments.mjs",
    "test": "vitest run",
    "test:written-judge": "vitest run src/lib/written-question-checks.test.ts",
    "stem-repetition": "node scripts/run-stem-repetition.mjs",
    "copy-pdf-worker": "node scripts/copy-pdf-worker.mjs",
    "write-build-id": "node scripts/write-build-id.mjs",
    "postinstall": "npm run copy-pdf-worker"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@embedpdf/react-pdf-viewer": "^2.14.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "js-beautify": "^1.15.4",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "next-themes": "^0.4.6",
    "pdfjs-dist": "4.8.69",
    "react": "19.2.4",
    "react-confetti": "^6.4.0",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "react-pdf": "9.2.1",
    "react-resizable-panels": "^4.11.2",
    "recharts": "^3.8.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.10.0",
    "shiki": "^4.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "overrides": {
    "postcss": ">=8.5.10",
    "react-pdf": {
      "pdfjs-dist": "4.8.69"
    }
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/js-beautify": "^1.14.3",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "jsdom": "^26.0.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
